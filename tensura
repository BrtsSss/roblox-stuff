-- Fade in Animation for main frame (on script load) - SLOWER and covers border as well
task.spawn(function()
    local tr = 1
    local fadeStep = 0.012 -- slower fade (was 0.04)
    while tr > 0 do
        tr = math.max(0, tr - fadeStep)
        frame.BackgroundTransparency = tr
        topBar.BackgroundTransparency = tr * 0.5
        tabPanel.BackgroundTransparency = tr * 0.5
        borderStroke.Transparency = 0.5 + tr*0.5 -- border fades in too
        task.wait(0.03)
    end
    frame.BackgroundTransparency = 0
    topBar.BackgroundTransparency = 0
    tabPanel.BackgroundTransparency = 0
    borderStroke.Transparency = 0.5
end)

-- Border color animation loop (moves the gradient's offset, smoothly animating around border)
task.spawn(function()
    local t = 0
    while true do
        t += 0.015
        -- Animate offset to make colors move!
        borderGradient.Offset = Vector2.new(math.sin(t)*0.35, math.cos(t*0.73)*0.35)
        -- Simulate a glowing effect by slightly modulating the thickness/transparency for a soft pulse
        borderStroke.Transparency = 0.35 + math.abs(math.sin(t*1.1))*0.16
        task.wait(0.025)
    end
end)
