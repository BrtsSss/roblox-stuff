-- The actual auto-race task
local ROLL_DELAY = 0.01
task.spawn(function()
    while true do
        if autoRaceEnabled() then
            local TARGET_RACE = raceDropdown()
            local rolling = true
            while autoRaceEnabled() and rolling do
                local success, result = pcall(function()
                    return rollRaceRemote:InvokeServer()
                end)
                if success then
                    local currentRace = raceValue.Value
                    if currentRace == TARGET_RACE then
                        rolling = false
                        break
                    end
                end
                task.wait(ROLL_DELAY)
            end
        end
        task.wait(0.1)
    end
end)

