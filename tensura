--// AUTO COMBAT
local skillOrder = {8,7,6,5,4,3,2,1}
local index = 1

combatRemote.OnClientInvoke = function(...)
    if combatEnabled() then
        local skill = skillOrder[index]
        index += 1
        if index > #skillOrder then index = 1 end
        return skill
    elseif skipEnabled() then
        return "skipturn"
    end
    return "skipturn"
end

