-- Allow color gradient preset changing for all UI gradients and border
local function setGUIGradientPreset(newPreset)
    selectedGradientPreset = newPreset
    -- main background
    mainGradient.Color = createGradientFromPreset(newPreset).Color
    -- header
    topGradient.Color = createGradientFromPreset(newPreset).Color
    -- tab panel
    tabGradient.Color = createGradientFromPreset(newPreset).Color
    -- border
    local preset = gradientPresets[newPreset] or gradientPresets["Mono"]
    local keypoints = {}
    for _, data in ipairs(preset) do
        table.insert(keypoints, ColorSequenceKeypoint.new(data[1], data[2]))
    end
    borderGradient.Color = ColorSequence.new(keypoints)
end

