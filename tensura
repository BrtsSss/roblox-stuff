--// HELPER FUNCTIONS
local function createToggle(name, yPos)
    local toggle = Instance.new("TextButton")
    toggle.Parent = frame
    toggle.Size = UDim2.new(0, 240, 0, 30)
    toggle.Position = UDim2.new(0, 20, 0, yPos)
    toggle.BackgroundColor3 = Color3.fromRGB(150, 50, 50) -- red = OFF
    toggle.TextColor3 = Color3.fromRGB(255, 255, 255)
    toggle.Font = Enum.Font.SourceSans
    toggle.TextSize = 16
    toggle.Text = name .. ": OFF"
    local enabled = false

    toggle.MouseButton1Click:Connect(function()
        enabled = not enabled
        toggle.Text = name .. (enabled and ": ON" or ": OFF")
        toggle.BackgroundColor3 = enabled and Color3.fromRGB(50, 150, 50) or Color3.fromRGB(150, 50, 50)
    end)
    return function() return enabled end
end

local function createDropdown(name, options, yPos)
    local dropdown = Instance.new("TextButton")
    dropdown.Parent = frame
    dropdown.Size = UDim2.new(0, 240, 0, 30)
    dropdown.Position = UDim2.new(0, 20, 0, yPos)
    dropdown.BackgroundColor3 = guiColor
    dropdown.TextColor3 = Color3.fromRGB(255, 255, 255)
    dropdown.Font = Enum.Font.SourceSans
    dropdown.TextSize = 16
    dropdown.Text = name .. ": " .. options[1]

    local selected = options[1]
    local open = false

    local listFrame = Instance.new("Frame")
    listFrame.Parent = frame
    listFrame.Size = UDim2.new(0, 240, 0, #options * 25)
    listFrame.Position = UDim2.new(0, 20, 0, yPos + 30)
    listFrame.BackgroundColor3 = guiColor
    listFrame.Visible = false

    local corner = Instance.new("UICorner", listFrame)
    corner.CornerRadius = UDim.new(0, 6)

    for i, option in ipairs(options) do
        local btn = Instance.new("TextButton")
        btn.Parent = listFrame
        btn.Size = UDim2.new(1, 0, 0, 25)
        btn.Position = UDim2.new(0, 0, 0, (i-1)*25)
        btn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.Font = Enum.Font.SourceSans
        btn.TextSize = 14
        btn.Text = option

        btn.MouseButton1Click:Connect(function()
            selected = option
            dropdown.Text = name .. ": " .. option
            listFrame.Visible = false
            open = false
        end)
    end

    dropdown.MouseButton1Click:Connect(function()
        open = not open
        listFrame.Visible = open
    end)

    return function() return selected end
end

